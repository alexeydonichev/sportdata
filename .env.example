# ============================================
# SPORTDATA PLATFORM — Environment Variables
# cp .env.example .env && fill real values
# ============================================

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sportdata
POSTGRES_USER=sportdata_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- API Gateway (Go) ----
API_HOST=0.0.0.0
API_PORT=8080
API_ENV=development
PASETO_SECRET_KEY=CHANGE_ME_32_BYTES_HEX_STRING_HERE
JWT_EXPIRY_HOURS=24
RATE_LIMIT_PER_MINUTE=60

# ---- Superadmin (hidden from UI) ----
SUPERADMIN_EMAIL=admin@yourfit.ru
SUPERADMIN_PASSWORD=CHANGE_ME

# ---- Encryption (AES-256 for marketplace API keys) ----
ENCRYPTION_KEY=CHANGE_ME_32_BYTES_HEX
CREDENTIALS_MASTER_KEY=CHANGE_ME_32_BYTES_HEX

# ---- Inter-service auth ----
ETL_SERVICE_SECRET=CHANGE_ME_RANDOM_TOKEN
ETL_SECRET=CHANGE_ME_RANDOM_TOKEN
CRON_SECRET=CHANGE_ME_RANDOM_TOKEN

# ---- Frontend (Next.js) ----
# DB connection (same postgres, used by Next.js API routes)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sportdata
DB_USER=sportdata_admin
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

JWT_SECRET=CHANGE_ME_MUST_MATCH_PASETO_SECRET
NEXT_PUBLIC_APP_NAME=SportData
NEXT_PUBLIC_API_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ---- ETL Worker ----
DATABASE_URL=postgres://sportdata_admin:CHANGE_ME_STRONG_PASSWORD@postgres:5432/sportdata?sslmode=disable
