# ============================================
# SportData Platform — Environment Variables
# ============================================

# PostgreSQL
POSTGRES_DB=sportdata
POSTGRES_USER=sportdata_admin
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_PORT=6379

# API Gateway
API_PORT=8080
PASETO_SECRET_KEY=CHANGE_ME_min_32_chars_paseto_secret_key_here!!
JWT_EXPIRY_HOURS=24
ENCRYPTION_KEY=CHANGE_ME_64_hex_chars_openssl_rand_hex_32
RATE_LIMIT_PER_MINUTE=120

# ETL Service
ETL_SERVICE_SECRET=CHANGE_ME_etl_secret

# Superadmin (создаётся автоматически при старте)
SUPERADMIN_EMAIL=admin@yourfit.ru
SUPERADMIN_PASSWORD=CHANGE_ME_admin_password
SUPERADMIN_TOTP_SECRET=CHANGE_ME_base32_totp_secret
